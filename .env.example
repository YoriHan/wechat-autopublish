DEEPSEEK_API_KEY=sk-...

# WeChat — optional; leave blank to skip WeChat output
WECHAT_APP_ID=wx...
WECHAT_APP_SECRET=...
WECHAT_COVER_MEDIA_ID=...

# Notion — optional; fill both to write articles to Notion instead
NOTION_TOKEN=ntn_...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notifications (optional)
BARK_KEY=...
PUSHPLUS_TOKEN=

# Optional: auto-generate cover images (set one of these)
GEMINI_API_KEY=
OPENAI_API_KEY=
