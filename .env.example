DEEPSEEK_API_KEY=sk-...

# WeChat — optional; leave blank to skip WeChat output
WECHAT_APP_ID=wx...
WECHAT_APP_SECRET=...
WECHAT_COVER_MEDIA_ID=...

# Notion — fill both to write translated articles here
NOTION_TOKEN=ntn_...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 每日候选库 — Top 5 文章存这里，改 Status=「选中」决定发哪篇
# 在 Notion 新建一个空白全页数据库，把 ID 填在这里（字段自动建好）
NOTION_CANDIDATES_DATABASE_ID=3492f695bbdb803d80f0c576ba5a4e68

# Notifications (optional)
BARK_KEY=...
PUSHPLUS_TOKEN=

# RSSHub — for Twitter/X RSS feeds
# Leave blank to use public rsshub.app (may be unreliable for Twitter)
# Self-host: docker run -d -p 1200:1200 diygod/rsshub
# Then set RSSHUB_BASE_URL=http://your-server:1200
RSSHUB_BASE_URL=
